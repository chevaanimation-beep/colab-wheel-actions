name: Build and Release for Colab (Vulkan)

on:
  workflow_dispatch: 
  push:
    tags:
      - 'v*'

permissions:
  contents: write 

jobs:
  build-and-release:
    runs-on: ubuntu-22.04
    
    steps:
    - name: Checkout Target Repository
      uses: actions/checkout@v4
      with:
        repository: predict-woo/qwen3-tts.cpp
        submodules: recursive

    # ================= 替换为：安装 Vulkan 编译依赖 =================
    - name: Install Vulkan SDK and Dependencies
      run: |
        sudo apt-get update
        # libvulkan-dev: Vulkan 头文件和 loader
        # shaderc: 提供 glslc，ggml 编译 Vulkan 着色器必需
        # vulkan-tools: 提供 vulkaninfo，可用于验证环境
        sudo apt-get install -y libvulkan-dev shaderc vulkan-tools
        
        # 验证 glslc 是否安装成功
        glslc --version
    # =================================================================

    - name: Build GGML with Vulkan
      run: |
        # 开启 Vulkan 后端
        cmake -S ggml -B ggml/build -DGGML_VULKAN=ON
        cmake --build ggml/build --config Release -j$(nproc)

    - name: Build qwen3-tts.cpp
      run: |
        cmake -S . -B build
        cmake --build build --config Release -j$(nproc)

    - name: Package Artifacts
      run: |
        mkdir -p colab_dist
        cp build/qwen3-tts-cli colab_dist/
        
        # 查找并复制编译出的动态链接库 (如 libggml-vulkan.so)
        find ggml/build build -name "*.so*" -exec cp -d {} colab_dist/ \; 2>/dev/null || true
        
        # 打包输出
        tar -czvf qwen3-tts-colab.tar.gz -C colab_dist .

    - name: Create or Update Release
      uses: ncipollo/release-action@v1
      with:
        tag: "colab-vulkan-latest" # 建议换个 tag 名，以免和 CUDA 版本冲突
        name: "Qwen3-TTS.cpp Colab Latest Build (Vulkan)"
        artifacts: "qwen3-tts-colab.tar.gz"
        allowUpdates: true
        replacesArtifacts: true
        makeLatest: true
        body: |
          Automated build for Google Colab (Ubuntu 22.04 + Vulkan).
          **How to use in Colab:**
          ```bash
          !wget -q https://github.com/${{ github.repository }}/releases/download/colab-vulkan-latest/qwen3-tts-colab.tar.gz
          !tar -xzvf qwen3-tts-colab.tar.gz
          ```
